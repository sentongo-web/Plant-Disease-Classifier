# .env.example — Template for secrets
#
# Copy this file to `.env` and fill in your real values.
# The `.env` file is listed in .gitignore and will NEVER be committed.
#
# Usage:  python-dotenv loads this automatically from src/utils/config.py
#         Alternatively: export KAGGLE_USERNAME=yourname  (in your shell)

# ── Kaggle API credentials ────────────────────────────────────────────────────
# Find these in your Kaggle profile → Settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Optional: MLflow remote tracking ─────────────────────────────────────────
# Leave blank to use local file storage (default)
MLFLOW_TRACKING_URI=
